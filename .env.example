# Arctic Defense Opportunity Scraper - Environment Variables
# Copy this file to .env and fill in your API keys

# SAM.gov API Key (required)
# Get one at: https://sam.gov (Account Settings > API Key)
SAM_GOV_API_KEY=your-sam-gov-api-key-here

# Google Gemini API Key (required for arctic relevance filtering)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
